{
  "name": "@ruknds/vue",
  "version": "2.2.0",
  "description": "Vue wrappers for Rukn Design System — RTL-first components for Arabic, Urdu, and multilingual apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "rukn",
    "design-system",
    "vue",
    "rtl",
    "arabic",
    "urdu",
    "web-components",
    "multilingual",
    "i18n"
  ],
  "peerDependencies": {
    "vue": ">=3.2.0"
  },
  "dependencies": {
    "@ruknds/core": "^2.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfaizanatiq/RuknDesignSystem",
    "directory": "wrappers/vue"
  },
  "homepage": "https://github.com/mfaizanatiq/RuknDesignSystem#readme",
  "author": "M Faizan Atiq"
}
